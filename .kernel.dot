digraph "CFG for 'kernel' function" {
	label="CFG for 'kernel' function";

	Node0x3ea6d4b0 [shape=record,color="#3d50c3ff", style=filled, fillcolor="#b9d0f970",label="{entry:\l  br label %loop\l}"];
