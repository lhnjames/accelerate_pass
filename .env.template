# Deepseek API 配置
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-reasoner
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
LLM_TIMEOUT=60
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.5

# LLVM 编译器路径
CLANG_PATH=/usr/bin/clang
CLANG_CXX_PATH=/usr/bin/clang++
OPT_PATH=/usr/bin/opt
LLC_PATH=/usr/bin/llc

# COMET 系统参数
MCTS_ITERATIONS=300
MCTS_DEPTH=30
MIN_PASS_SEQUENCE_LENGTH=4
MAX_PASS_SEQUENCE_LENGTH=30
PUCT_EXPLORATION_CONSTANT=1.5
EXPANSION_VISIT_THRESHOLD=3
MEASURE_VISIT_THRESHOLD=5
PERIODIC_MEASURE_INTERVAL=20
TOTAL_RUNTIME_BUDGET=100
LLM_CALL_BUDGET=20
KB_CONFIDENCE_THRESHOLD=0.3

# 输出和日志
LOG_LEVEL=INFO
OUTPUT_DIR=./outputs
VERBOSE=false
